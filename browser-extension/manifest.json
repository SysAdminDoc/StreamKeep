{
  "manifest_version": 3,
  "name": "StreamKeep Companion",
  "version": "1.0.0",
  "description": "One-click send of the current page URL to the StreamKeep desktop app.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://127.0.0.1/*"],
  "action": {
    "default_title": "Send to StreamKeep",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
