<?xml version="1.0" encoding="UTF-8"?>
<MPD xmlns="urn:mpeg:dash:schema:mpd:2011" type="static"
     mediaPresentationDuration="PT2H" minBufferTime="PT2S">
  <Period id="p1" duration="PT1H">
    <AdaptationSet mimeType="video/mp4" contentType="video">
      <Representation id="v1" width="1920" height="1080" bandwidth="5000000">
        <BaseURL>period1_1080p.mp4</BaseURL>
      </Representation>
      <Representation id="v2" width="1280" height="720" bandwidth="2500000">
        <BaseURL>period1_720p.mp4</BaseURL>
      </Representation>
    </AdaptationSet>
  </Period>
  <Period id="p2" duration="PT1H">
    <AdaptationSet mimeType="video/mp4" contentType="video">
      <Representation id="v3" width="1920" height="1080" bandwidth="5000000">
        <BaseURL>period2_1080p.mp4</BaseURL>
      </Representation>
    </AdaptationSet>
  </Period>
</MPD>
